# AgentPI Service
AGENTPI_PORT=4010
AGENTPI_ISSUER=https://agentpi.local
AGENTPI_KEYS_DIR=.keys
AGENTPI_DEFAULT_SCOPES=read
AGENTPI_DEFAULT_RPM=10
AGENTPI_DEFAULT_DAILY_QUOTA=100
AGENTPI_DEFAULT_CONCURRENCY=1
# Comma-separated hard blocklist, e.g. agent-a,agent-b
AGENTPI_BLOCKED_AGENTS=
# Optional admin key for fast revoke endpoints
AGENTPI_ADMIN_KEY=
# Optional per-agent policy JSON:
# AGENTPI_AGENT_POLICIES={"agent-123":{"scopes":["read","write"],"limits":{"rpm":30,"dailyQuota":1000,"concurrency":2}}}
AGENTPI_AGENT_POLICIES=
# Optional per-tool policy JSON (customer/tool overrides):
# AGENTPI_TOOL_POLICIES={"tool_example":{"scopes":["read","write"],"limits":{"rpm":60,"dailyQuota":5000,"concurrency":3}}}
AGENTPI_TOOL_POLICIES=

# Tool registration
TOOL_ID=tool_example

# Example Tool API
TOOL_PORT=4020
DATABASE_URL=postgresql://agentpi:agentpi@localhost:5432/agentpi

# JWKS URL used by tool SDKs to verify connect grants.
# In production this MUST use HTTPS. For local development, point to the
# local service over HTTP (the HTTPS check is skipped when NODE_ENV != production).
AGENTPI_JWKS_URL=http://localhost:4010/.well-known/jwks.json

# Agent CLI
AGENTPI_SERVICE_URL=http://localhost:4010
AGENT_UID=agent-xxxxxxxxxxxxxxxxxxxxxxxx
AGENT_PRIVATE_JWK={"crv":"Ed25519","d":"...","x":"...","kty":"OKP","kid":"..."}
