datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Workspace {
  id        String      @id @default(uuid())
  orgId     String      @unique
  name      String      @db.VarChar(255)
  planId    String      @default("free")
  createdAt DateTime    @default(now())
  agents    ToolAgent[]
}

model ToolAgent {
  id             String    @id @default(uuid())
  workspaceId    String
  agentpiAgentId String
  status         String    @default("active")
  scopes         String[]  @default([])
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, agentpiAgentId])
}

// NOTE: A ToolApiKey model with a hashedSecret column was previously defined
// here but had no hashing/validation implementation, making it a ghost schema.
// It has been removed until the API key issuance and verification flow is fully
// implemented (hash with argon2/bcrypt, compare with timingSafeEqual).

model Idempotency {
  id           String   @id @default(uuid())
  key          String
  toolId       String
  orgId        String
  requestHash  String
  responseJson String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([key, orgId, toolId])
}

model UsedJti {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime
}
